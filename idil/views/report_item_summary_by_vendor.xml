<odoo>
    <record id="view_vendor_statement_with_items_report_wizard_form" model="ir.ui.view">
        <field name="name">idil.item.summary.with.vendor.form</field>
        <field name="model">idil.item.summary.with.vendor</field>
        <field name="arch" type="xml">
            <form string="Item Summary Report With Vendors">
                <group>
                    <field name="vendor_id"/>
                    <field name="start_date"/>
                    <field name="end_date"/>
                </group>
                <footer>
                    <button string="View Report" type="object" name="view_report" class="btn-primary"/>
                    <button string="Download PDF Report" type="object" name="generate_pdf_report" class="btn-secondary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
    
    <!-- View form for displaying the report before download -->
    <record id="item_summary_report_view_form" model="ir.ui.view">
        <field name="name">idil.item.summary.report.view.form</field>
        <field name="model">idil.item.summary.with.vendor</field>
        <field name="arch" type="xml">
            <form string="Item Summary Report">
                <!-- We're avoiding attrs that depend on fields that might not exist yet -->
                <h2>Item Summary Report</h2>
                <div>
                    <field name="report_data" widget="pdf_viewer"/>
                </div>
                <footer>
                    <button string="Download Report" type="object" name="download_report" class="btn-primary"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_item_summary_with_vendor_report_wizard" model="ir.actions.act_window">
        <field name="name">Item Summary With Vendor</field>
        <field name="res_model">idil.item.summary.with.vendor</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>