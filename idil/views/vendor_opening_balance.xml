<odoo>
    <record id="view_tree_idil_vendor_opening_balance" model="ir.ui.view">
        <field name="name">idil.vendor.opening.balance.tree</field>
        <field name="model">idil.vendor.opening.balance</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="total_amount" sum="total"/>
                <field name="date"/>
                <field name="state"/>
                <field name="currency_id"/>
                <field name="rate"/>
                <field name="internal_comment"/>
            </tree>
        </field>
    </record>

    <record id="view_form_idil_vendor_opening_balance" model="ir.ui.view">
        <field name="name">idil.vendor.opening.balance.form</field>
        <field name="model">idil.vendor.opening.balance</field>
        <field name="arch" type="xml">
            <form string="Vendor Opening Balance">
                <header>
                    <button name="action_confirm" string="Confirm" type="object" class="btn-primary"/>
                    <button name="action_cancel" string="Cancel" type="object" class="btn-secondary"/>
                    <button name="action_reset_to_draft" string="Reset to Draft" type="object" class="btn-secondary"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,posted,cancel"/>
                </header>
                <sheet>
                    <group string="Opening Balance Info">
                        <field name="name" readonly="1"/>
                        <field name="date"/>
                        <field name="currency_id"/>
                        <field name="rate"/>
                    </group>

                    <group>
                        <field name="internal_comment"/>
                    </group>
                    
                    <notebook>
                        <page string="Lines">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="vendor_id"/>
                                    <field name="account_id" readonly="1"/>
                                    <field name="account_currency_id" readonly="1"/>
                                    <field name="amount" sum="Total"/>
                                </tree>
                            </field>
                        </page>

                        <!-- Audit tab: only visible after at least one action -->
                        <page string="Audit Trail">
                            <group string="Cancellation">
                                <field name="cancelled_by" readonly="1"/>
                                <field name="cancelled_date" readonly="1"/>
                            </group>
                            <group string="Reset to Draft">
                                <field name="reset_to_draft_by" readonly="1"/>
                                <field name="reset_to_draft_date" readonly="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_idil_vendor_opening_balance" model="ir.actions.act_window">
        <field name="name">Vendor Opening Balances</field>
        <field name="res_model">idil.vendor.opening.balance</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_tree_idil_vendor_opening_balance"/>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p>Use this menu to manage vendor opening balances.</p>
        </field>
    </record>
</odoo>